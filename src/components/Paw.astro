---
import PawPrint from '@/assets/icons/paw-print.svg';

interface Props {
	top?: string;
	bottom?: string;
	left?: string;
	right?: string;
	size: string;
	rotate: string;
}

const { top, bottom, left, right, size, rotate } = Astro.props;

const positionStyles = [
	top && `top: ${top}`,
	bottom && `bottom: ${bottom}`,
	left && `left: ${left}`,
	right && `right: ${right}`,
	`width: ${size}`,
	`height: ${size}`,
	`transform: rotate(${rotate})`,
]
	.filter(Boolean)
	.join('; ');
---

<PawPrint
	aria-hidden="true"
	class="fill-peach pointer-events-none fixed z-0 opacity-15 drop-shadow-[0_2px_4px_rgba(255,155,130,0.3)]"
	style={positionStyles}
/>
